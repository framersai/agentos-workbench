{
  "name": "@framersai/agentos-workbench",
  "version": "0.1.0",
  "private": true,
  "description": "Developer cockpit for AgentOS sessions: inspect personas, debug tool calls, and replay streaming transcripts.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx src/lib/taskOutcomeHealthFilters.test.ts",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint \"src/**/*.{ts,tsx}\" --max-warnings=0",
    "e2e": "playwright test",
    "e2e:workbench": "playwright test tests/e2e/workbench-*.spec.ts",
    "e2e:core": "playwright test tests/e2e/workbench-core.spec.ts",
    "e2e:eval-planning": "playwright test tests/e2e/workbench-eval-planning.spec.ts",
    "e2e:quality": "playwright test tests/e2e/workbench-quality.spec.ts",
    "e2e:screenshots": "playwright test tests/e2e/workbench-screenshots.spec.ts",
    "e2e:smoke:pw": "playwright test tests/e2e/smoke.spec.ts",
    "e2e:report": "playwright show-report",
    "e2e:smoke": "tsx e2e-test.ts"
  },
  "dependencies": {
    "@framers/agentos": "*",
    "@framers/sql-storage-adapter": "*",
    "@framers/theme-tokens": "^0.1.0",
    "@hookform/resolvers": "^3.6.0",
    "@tanstack/react-query": "^5.51.0",
    "clsx": "^2.1.1",
    "i18next": "^23.11.5",
    "i18next-browser-languagedetector": "^7.1.0",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-i18next": "^15.0.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.26.0",
    "socket.io-client": "^4.8.1",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.12",
    "@types/react": "^18.3.6",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.35.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "tsx": "^4.19.0",
    "vite": "^5.4.10",
    "vite-plugin-node-polyfills": "^0.22.0"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "packageManager": "pnpm@10.15.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/framersai/agentos-workbench"
  }
}
